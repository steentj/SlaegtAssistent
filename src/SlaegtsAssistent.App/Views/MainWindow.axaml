<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SlaegtsAssistent.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SlaegtsAssistent.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SlaegtsAssistent">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid ColumnDefinitions="280,*" Margin="12" ColumnSpacing="12">
        <Border Grid.Column="0" BorderThickness="1" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="People" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ListBox ItemsSource="{Binding People}" SelectedItem="{Binding SelectedPerson}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PersonListItemViewModel">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <TabControl Grid.Column="1">
            <TabItem Header="Editor">
                <Border Padding="12">
                    <TextBlock Text="Editor placeholder" />
                </Border>
            </TabItem>
            <TabItem Header="Preview">
                <Border Padding="12">
                    <TextBlock Text="Preview placeholder" />
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
