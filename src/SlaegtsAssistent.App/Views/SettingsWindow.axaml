<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SlaegtsAssistent.App.ViewModels"
        x:Class="SlaegtsAssistent.App.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Width="700"
        Height="260"
        CanResize="False"
        Title="Indstillinger"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto" ColumnDefinitions="*,Auto" RowSpacing="12" ColumnSpacing="8">
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Standard folder for GEDCOM filer (input)" FontWeight="SemiBold" />
        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding DefaultGedcomInputFolder, Mode=TwoWay}" />
        <Button Grid.Row="1" Grid.Column="1" Content="Vælg…" Command="{Binding SelectGedcomInputFolderCommand}" MinWidth="90" />

        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Standard folder for markdown filer (output)" FontWeight="SemiBold" VerticalAlignment="Top" />
        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,24,0,0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" Text="{Binding DefaultMarkdownOutputFolder, Mode=TwoWay}" />
            <Button Grid.Column="1" Content="Vælg…" Command="{Binding SelectMarkdownOutputFolderCommand}" MinWidth="90" />
        </Grid>

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Annuller" Command="{Binding CancelCommand}" MinWidth="90" />
            <Button Content="Gem" Command="{Binding SaveCommand}" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
